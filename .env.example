# ===========================================
# Carbey - Environment Variables Template
# ===========================================
# Copy to `.env` for Next.js and to `.env.python` for the Python scraper.

# ===========================================
# Next.js — Supabase (required)
# ===========================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Server-side only: cron jobs (/api/sync, /api/cron/daily-summary) and admin DB access
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ===========================================
# Next.js — Vercel Cron (production)
# ===========================================
# Must match Authorization: Bearer <secret> on GET /api/sync and /api/cron/daily-summary

CRON_SECRET=use_a_long_random_string_min_16_chars

# Public site URL for email links (optional; falls back to VERCEL_URL in production)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ===========================================
# Next.js — Daily email summary (optional)
# ===========================================
# Requires SMTP below + CRON in vercel.json + SUPABASE_SERVICE_ROLE_KEY.
# Recipients (comma-separated).

DAILY_SUMMARY_TO=ops@example.com

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Optional: defaults to SMTP_USER
SMTP_FROM=
# Use true for port 465
SMTP_SECURE=false

# ===========================================
# Next.js — Pricing guardrails (optional)
# ===========================================

PRICING_MIN_PRICE_YEN=0
PRICING_MIN_MARGIN_YEN=100000
PRICING_MAX_DISCOUNT_PCT=25
PRICING_MAX_DISCOUNT_YEN=500000

# ===========================================
# Next.js — Build / runtime (optional)
# ===========================================
# If Turbopack resolves .venv python symlink incorrectly:
# PYTHON_PATH=/absolute/path/to/.venv/bin/python

# ===========================================
# Python scraper (.env.python)
# ===========================================

CMATCH_LOGIN_ID=your_login_id_here
CMATCH_PASSWORD=your_password_here

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_service_role_key_here
SUPABASE_TABLE=inventories
SUPABASE_CONFLICT_COLUMN=vehicle_code

SCRAPING_DELAY=2
MAX_RETRIES=3
REQUEST_TIMEOUT=60000
BROWSER_HEADLESS=true
BROWSER_SLOW_MO=0
LOG_LEVEL=INFO

# Optional integrations
WEBHOOK_URL=
