# ===========================================
# Carbey - Environment Variables Template
# ===========================================
# Copy this file to .env and .env.python and fill in your values

# ===========================================
# Next.js Environment Variables
# ===========================================
# (Used by Next.js application)

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ===========================================
# Python Environment Variables
# ===========================================
# (Used by Python scraper - also save as .env.python)

# C-MATCH Login Credentials (Required)
CMATCH_LOGIN_ID=your_login_id_here
CMATCH_PASSWORD=your_password_here

# Supabase (Required for DB sync)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_service_role_key_here
SUPABASE_TABLE=inventories
SUPABASE_CONFLICT_COLUMN=vehicle_code

# Scraping Settings (Optional)
SCRAPING_DELAY=2              # Seconds between requests (default: 2)
MAX_RETRIES=3                 # Retry attempts (default: 3)
REQUEST_TIMEOUT=60000         # Request timeout in ms (default: 60000)

# Browser Settings (Optional)
BROWSER_HEADLESS=true         # Run browser in background (default: true)
BROWSER_SLOW_MO=0             # Slow down browser actions in ms (default: 0)

# Logging (Optional)
LOG_LEVEL=INFO                # DEBUG, INFO, WARNING, ERROR (default: INFO)

# Notifications (Optional)
WEBHOOK_URL=                  # Slack/Discord webhook for notifications
